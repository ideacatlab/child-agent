# --- secrets: never commit these ---
.env
.env.*
!.env.example
secrets/
*.token
*.key
*cookies*.json

# --- runtime state (private, machine-local) ---
# ignore workspace contents but keep the directory placeholder
workspace/*
!workspace/.gitkeep

# --- python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# --- editors / os ---
.idea/
.vscode/
.DS_Store
