# ============================================================================
# agent runtime configuration — copy to `.env` and fill in. `.env` is gitignored.
#
# NOTE: there is NO Anthropic API key here. The brain — and every spawned worker
# and the supervisor — is a `claude` process on your subscription, not an LLM API.
# There is no per-token cost. Everything below is optional.
# ============================================================================

# --- identity -------------------------------------------------------------
# Empty in the base template. Give this deployment a name when you fork it.
AGENT_NAME=

# --- behavior the master prompt enforces ----------------------------------
# Ask the operator before destructive / outward-facing actions (e.g. git push).
AGENT_CONFIRM_DANGEROUS=1
# Whether the agent may publish (commit+push) at all.
AGENT_ALLOW_PUBLISH=1

# --- the fleet: spawned worker / supervisor agents ------------------------
# The `claude` CLI the runner shells out to spawn workers.
AGENT_CLAUDE_BIN=claude
# Model for spawned workers (empty = inherit the CLI default).
AGENT_WORKER_MODEL=
# Max simultaneous worker processes.
AGENT_FLEET_MAX_CONCURRENCY=3
# Per-worker hard timeout, seconds.
AGENT_FLEET_TIMEOUT=1800
# Permission mode for workers: bypassPermissions (full autonomy) | acceptEdits | default
AGENT_FLEET_PERMISSION_MODE=bypassPermissions
# Isolate file-mutating parallel workers in their own git worktree (1 to enable).
AGENT_FLEET_WORKTREE=0
# Always-on supervision cadence (e.g. 30m, 2h). Empty = no automatic supervision.
AGENT_SUPERVISE_EVERY=

# --- Telegram (optional) --------------------------------------------------
# Create a bot with @BotFather and paste the token. chat_id auto-captures on the
# first message the bot receives.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Comma-separated Telegram user IDs allowed to command the agent (empty = anyone
# in chats the bot is in; SET THIS for anything non-private).
TELEGRAM_ALLOWED_USER_IDS=

# --- RAG / embeddings (optional) ------------------------------------------
# Backend: hashing (zero-dep, free default) | sentence-transformers (local, free)
#          | voyage | openai  (the last two are hosted and DO cost money)
AGENT_EMBEDDING_BACKEND=hashing
AGENT_EMBEDDING_MODEL=
AGENT_EMBEDDING_DIM=512
# only needed if you opt into a hosted embedding backend
VOYAGE_API_KEY=
OPENAI_API_KEY=

# --- self-publish to GitHub (optional) ------------------------------------
# When set, `agent publish commit` pushes here. SSH remote recommended.
AGENT_GIT_REMOTE=
GITHUB_TOKEN=
AGENT_GIT_AUTHOR=agent <agent@localhost>

# --- paths (optional) -----------------------------------------------------
# Where private runtime state lives. Defaults to ./workspace
AGENT_WORKSPACE=
