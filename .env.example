# ============================================================================
# scion configuration — copy to `.env` and fill in. `.env` is gitignored.
# Every value here can also be supplied as a real environment variable.
# ============================================================================

# --- LLM (required) -------------------------------------------------------
# Your Anthropic API key. Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Model + reasoning effort. Defaults are sensible; override only if needed.
SCION_MODEL=claude-opus-4-8
SCION_EFFORT=high              # low | medium | high | xhigh | max
SCION_MAX_TOKENS=16000
SCION_THINKING=adaptive        # adaptive | off

# --- identity -------------------------------------------------------------
SCION_AGENT_NAME=Scion

# --- autonomy & safety ----------------------------------------------------
# autonomous=1 lets the worker drain the task queue and act without a human in
# the loop. require_confirmation gates DANGEROUS tools behind an approval step
# (asked over the active channel, e.g. Telegram).
SCION_AUTONOMOUS=0
SCION_REQUIRE_CONFIRMATION=1
# Allow the agent to author + register brand-new tools for itself at runtime.
SCION_ALLOW_SELF_TOOLING=1
# Auto-apply self-authored tools that pass validation (else they wait for
# human approval). Leave 0 until you trust your setup.
SCION_TOOL_AUTOAPPLY=0

# --- Telegram (optional) --------------------------------------------------
# Create a bot with @BotFather and paste the token. chat_id auto-captures on
# the first message the bot receives in your chat/group.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Comma-separated Telegram user IDs allowed to command the agent (empty = all
# users in chats the bot is in; set this for anything public).
TELEGRAM_ALLOWED_USER_IDS=

# --- RAG / embeddings (optional) ------------------------------------------
# Backend: hashing (zero-dep default) | sentence-transformers | voyage | openai
SCION_EMBEDDING_BACKEND=hashing
SCION_EMBEDDING_MODEL=
# Voyage is Anthropic's recommended embeddings partner.
VOYAGE_API_KEY=
OPENAI_API_KEY=

# --- self-publish to GitHub (optional) ------------------------------------
# When set, `scion publish` commits authored tools + knowledge and pushes here.
# Use an SSH remote (git@github.com:you/your-agent.git) or an https remote with
# a token in GITHUB_TOKEN.
SCION_GIT_REMOTE=
GITHUB_TOKEN=
SCION_GIT_AUTHOR=scion <agent@localhost>

# --- paths (optional) -----------------------------------------------------
# Where private runtime state lives. Defaults to ./workspace
SCION_WORKSPACE=
