# ============================================================================
# scion configuration — copy to `.env` and fill in. `.env` is gitignored.
#
# NOTE: there is NO Anthropic API key here. scion's brain is a Claude Code
# session (your subscription) running `/loop scion autopilot` — there is no LLM
# API and no per-token cost. Everything below is optional.
# ============================================================================

# --- identity -------------------------------------------------------------
SCION_AGENT_NAME=Scion

# --- behavior the master prompt enforces ----------------------------------
# Ask the operator before destructive / outward-facing actions (e.g. git push).
SCION_CONFIRM_DANGEROUS=1
# Whether the agent may publish (commit+push) at all.
SCION_ALLOW_PUBLISH=1

# --- Telegram (optional) --------------------------------------------------
# Create a bot with @BotFather and paste the token. chat_id auto-captures on the
# first message the bot receives.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Comma-separated Telegram user IDs allowed to command the agent (empty = anyone
# in chats the bot is in; SET THIS for anything non-private).
TELEGRAM_ALLOWED_USER_IDS=

# --- RAG / embeddings (optional) ------------------------------------------
# Backend: hashing (zero-dep, free default) | sentence-transformers (local, free)
#          | voyage | openai  (the last two are hosted and DO cost money)
SCION_EMBEDDING_BACKEND=hashing
SCION_EMBEDDING_MODEL=
SCION_EMBEDDING_DIM=512
# only needed if you opt into a hosted embedding backend
VOYAGE_API_KEY=
OPENAI_API_KEY=

# --- self-publish to GitHub (optional) ------------------------------------
# When set, `scion publish commit` pushes here. SSH remote recommended.
SCION_GIT_REMOTE=
GITHUB_TOKEN=
SCION_GIT_AUTHOR=scion <agent@localhost>

# --- paths (optional) -----------------------------------------------------
# Where private runtime state lives. Defaults to ./workspace
SCION_WORKSPACE=
